# --- App ---
NODE_ENV=development
PORT=3000
HOST=localhost
FRONTEND_URL=http://localhost:3000

# --- Database (Supabase / Postgres + PgBouncer) ---
# DATABASE_URL: pooled connection (runtime via PrismaPg adapter)
# DIRECT_URL:   direct connection (prisma migrate, bypasses PgBouncer)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DB?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB

# --- Auth ---
# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Encode newlines as \n when pasting here
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Refresh token lifetime in days
REFRESH_TOKEN_TTL_DAYS=30

# --- Email (Resend) ---
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Token TTLs (milliseconds) ---
VERIFICATION_TOKEN_TTL_MS=86400000   # 24 hours
RESET_TOKEN_TTL_MS=3600000           # 1 hour

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=3600000         # 1 hour window
RATE_LIMIT_MAX_ATTEMPTS=3            # max attempts per window
